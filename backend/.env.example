# ============================================================
# InsureBridge Environment Variables — COPY TO .env
# ============================================================

# --- Application ---
APP_NAME="InsureBridge"
APP_VERSION="0.1.0"
ENVIRONMENT="development"          # development | staging | production
DEBUG=true
LOG_LEVEL="INFO"

# --- Database ---
# SQLite (default for POC):
DATABASE_URL="sqlite+aiosqlite:///./insurebridge.db"
# PostgreSQL (production):
# DATABASE_URL="postgresql+asyncpg://user:password@localhost:5432/insurebridge"

# --- Security ---
JWT_SECRET_KEY="CHANGE_ME_TO_A_LONG_RANDOM_SECRET_KEY_AT_LEAST_32_CHARS"
JWT_ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- CORS ---
ALLOWED_ORIGINS="http://localhost:3000,http://localhost:5173"

# --- File Storage ---
UPLOAD_DIR="./uploads"
MAX_FILE_SIZE_MB=10
ALLOWED_FILE_TYPES="pdf,jpg,jpeg,png,tiff"

# --- AI Services (Phase 2) ---
OPENAI_API_KEY="sk-..."
ANTHROPIC_API_KEY="sk-ant-..."
AI_MODEL="gpt-4o"
AI_TEMPERATURE=0.1
AI_MAX_TOKENS=2000

# --- OCR ---
TESSERACT_CMD="/usr/bin/tesseract"

# --- Vector Store (Phase 2) ---
CHROMA_DB_PATH="./chroma_db"
# PINECONE_API_KEY="..."           # Production vector DB
# PINECONE_ENVIRONMENT="..."

# --- Email (Phase 3) ---
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="noreply@insurebridge.com"
SMTP_PASSWORD="..."
EMAIL_FROM="InsureBridge <noreply@insurebridge.com>"

# --- Admin Seed User ---
ADMIN_EMAIL="admin@insurebridge.com"
ADMIN_PASSWORD="Admin@123456"
ADMIN_NAME="System Admin"
